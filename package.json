{
  "name": "foliolang",
  "version": "1.1.0",
  "description": "DSL declarativa para gerar portfólios estáticos (HTML + CSS).",
  "keywords": [
    "DSL",
    "portfolio",
    "static-site",
    "generator"
  ],
  "bin": {
    "folio": "./build/cli.js"
  },
  "main": "build/cli.js",
  "files": [
    "build"
  ],
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://github.com/TyranoT/FolioLang#readme",
  "bugs": {
    "url": "https://github.com/TyranoT/FolioLang/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TyranoT/FolioLang.git"
  },
  "license": "MIT",
  "author": "Italo Monteiro Leite",
  "type": "module",
  "scripts": {
    "dev": "tsx src/cli.ts dev example/italo.folio",
    "build": "tsc",
    "start": "node build/cli.js build example/italo.folio",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
